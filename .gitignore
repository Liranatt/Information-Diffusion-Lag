# ── Secrets ──────────────────────────────────────────────────────
.env
.env.*
*.key

# ── Virtual environments ─────────────────────────────────────────
.venv/
venv/
env/

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ── Backtest outputs (large, regenerable from the DB) ────────────
main_backtesting/output/
second_phase_testing/backtest_data/
theory_testing/trade_graphs/
theory_testing/backtest_cointegration/results/
database/plots/

# ── Scratch / local analysis ─────────────────────────────────────
scratch*.py

# ── IDE (may contain DB connection details) ──────────────────────
.idea/

# ── Data, Logs, and Experiment Results ───────────────────────────
*.csv
*.log
data/experiment_*
data/rf_experiment_*
data/opp_cost_trades.csv
main_backtesting/
!main_backtesting/**/*.py

# Policy artifacts that MUST travel with the code: the live trader loads its
# walk-forward policy from these (live/config.py). The monthly optimize_cem run
# regenerates them and they are pushed so the server picks up the new policy.
!data/experiment_walkforward_folds_clean.csv
!data/experiment_results_clean.csv
!data/backtest_equity_log.csv
!data/experiment_trade_logs_clean/
!data/experiment_trade_logs_clean/*.csv
!data/experiment_equity_logs_clean/
!data/experiment_equity_logs_clean/*.csv

# ── Namespaced run outputs (optimize_cem.py --run-id) ────────────
runs/